# PharmaTrack EMA alerts — configuration.
# Copy this file to  config.env  and fill in your own values.
# config.env is gitignored and must never be committed.

# --- Email delivery (Gmail example) ---
# 1. Your Gmail address:
SMTP_USER=bernd.gansbacher@gmail.com
# 2. A Google *App Password* (NOT your normal password). Create one at:
#       https://myaccount.google.com/apppasswords
#    (requires 2-Step Verification to be on). It looks like "abcd efgh ijkl mnop"
#    — paste it WITHOUT spaces:
SMTP_PASS=your16charapppassword
# 3. Where alerts go (defaults to SMTP_USER if omitted):
ALERT_TO=bernd.gansbacher@gmail.com

# Gmail SSL defaults — leave as-is unless you use a different provider.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# --- Optional scope ---
# Only alert on advanced-therapy medicines (ATMPs — the CAT remit):
# ALERT_ATMP_ONLY=true
